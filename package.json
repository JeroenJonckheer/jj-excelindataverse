{
  "name": "jj-excelindataverse",
  "version": "0.16.0",
  "description": "JJ - Excel in Dataverse - the spreadsheet experience Dataverse always should have had. A PCF dataset control for inline editing in Model-Driven Apps.",
  "private": true,
  "author": "Jeroen Jonckheer",
  "license": "MIT",
  "scripts": {
    "build": "pcf-scripts build",
    "clean": "pcf-scripts clean",
    "rebuild": "pcf-scripts rebuild",
    "start": "pcf-scripts start",
    "start:watch": "pcf-scripts start watch",
    "refreshTypes": "pcf-scripts refreshTypes",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "harness:build": "node harness/build.js",
    "test:e2e": "playwright test",
    "test:adversarial": "playwright test e2e/adversarial.spec.ts",
    "check:version": "node scripts/check-version.mjs",
    "demo": "playwright test --config=playwright.demo.config.ts",
    "test:all": "npm run verify",
    "verify": "npm run check:version && npm run refreshTypes && npm run lint && npm run typecheck && npm run test:coverage && npm run build && npm run test:e2e"
  },
  "dependencies": {
    "@fluentui/react-components": "9.46.2",
    "react": "16.14.0",
    "react-dom": "16.14.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.1",
    "@microsoft/eslint-plugin-power-apps": "^0.2.51",
    "@playwright/test": "^1.49.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^12.1.5",
    "@testing-library/user-event": "^13.5.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.17.10",
    "@types/powerapps-component-framework": "^1.3.16",
    "@types/react": "^16.14.60",
    "@types/react-dom": "^16.9.24",
    "esbuild": "^0.25.0",
    "eslint": "^9.25.1",
    "eslint-plugin-promise": "^7.1.0",
    "eslint-plugin-react": "^7.37.2",
    "globals": "^15.15.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "pcf-scripts": "^1",
    "pcf-start": "^1",
    "ts-jest": "^29.2.5",
    "typescript": "^5.8.3",
    "typescript-eslint": "8.44.0"
  }
}
